# Server Configuration
NODE_ENV=development
PORT=5000
HOST=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=done_deal_digital

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_REGION=us-west-2
AWS_S3_BUCKET=your_bucket_name_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_key_here
SENDGRID_FROM_EMAIL=noreply@donedealdigital.com

# OpenAI (Chatbot)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4

# Logging
LOG_LEVEL=info
